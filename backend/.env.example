PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=filmstocks

JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# Allowed frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173

# Max file size for uploads in bytes (10 MB)
MAX_FILE_SIZE=10485760

# Image storage. Use "local" for development or "s3" for S3-compatible storage.
STORAGE_DRIVER=local

# S3/R2/Spaces settings used when STORAGE_DRIVER=s3
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=
CDN_BASE_URL=
